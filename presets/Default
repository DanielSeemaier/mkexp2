#!/usr/bin/env zsh

# v2 default preset. Starts with Mock so install+generate works without network.

System local

# These are global properties. Any of these can be overridden per algorithm
# or per Experiment* function.
Property timelimit 01:00:00
Property slurm.partition cpuonly
Property slurm.use_array true
Property slurm.array.max_parallel 64
# Build-core limit is a CLI option, e.g.:
# mkexp2 install --build-max-cores 16
# Property slurm.install.mode job
# Property slurm.install.timelimit 02:00:00
# Property parse.auto true
# Property parse.slurm.timelimit 00:30:00
# AlgorithmProperty KaMinPar parser KaMinPar
# AlgorithmProperty KaMinPar parser ./parsers/KaMinParCustom.awk

# Example: override an algorithm repository and ref from the Experiment file.
# DefineAlgorithmVersion KaMinPar-Dev KaMinPar feature/my-branch
# AlgorithmProperty KaMinPar-Dev repo_url https://github.com/KaHIP/KaMinPar.git
# AlgorithmProperty KaMinPar-Dev repo_ref origin/feature/my-branch
# AlgorithmProperty KaMinPar-Dev cmake_flags -DKAMINPAR_64BIT_IDS=On

ExperimentBaseline() {
  Algorithms Mock

  Ks 2 4
  Seeds 1 2
  Epsilons 0.03
  Threads 1x1x4

  # Paths are without extension, same as mkexp v1 style.
  Graph /tmp/demo_graph

  Property timelimit 00:30:00
}

ExperimentStress() {
  Algorithms Mock

  Ks 2 4
  Seeds 1 2
  Epsilons 0.03
  Threads 1x1x4
  Graph /tmp/demo_graph

  # For slurm launcher, this means: submit ExperimentStress after
  # ExperimentBaseline finished OK (for the same topology).
  Property slurm.dependency afterok:ExperimentBaseline
  Property timelimit 02:00:00
}
