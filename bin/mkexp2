#!/usr/bin/env zsh
set -euo pipefail
# Do not inherit caller xtrace; it pollutes mkexp2 UI with raw assignments.
set +x

source_path="$0"
while [[ -L "$source_path" ]]; do
  script_dir=$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)
  source_path=$(readlink "$source_path")
  [[ $source_path != /* ]] && source_path="$script_dir/$source_path"
done
script_dir=$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)
MKEXP2_HOME=$(cd "$script_dir/.." && pwd)

. "$MKEXP2_HOME/bin/inc/state.sh"
. "$MKEXP2_HOME/bin/inc/util.sh"
. "$MKEXP2_HOME/bin/inc/dsl.sh"
. "$MKEXP2_HOME/bin/inc/props.sh"
. "$MKEXP2_HOME/bin/inc/plugins.sh"
. "$MKEXP2_HOME/bin/inc/expand.sh"
. "$MKEXP2_HOME/bin/inc/install.sh"
. "$MKEXP2_HOME/bin/inc/generate.sh"
. "$MKEXP2_HOME/bin/inc/parse.sh"
. "$MKEXP2_HOME/bin/inc/plot.sh"
. "$MKEXP2_HOME/bin/inc/check.sh"
. "$MKEXP2_HOME/bin/inc/probe.sh"
. "$MKEXP2_HOME/bin/inc/progress.sh"
. "$MKEXP2_HOME/bin/inc/cli.sh"

ParseCli "$@"

if [[ "$MKEXP2_MODE" == "help" ]]; then
  PrintHelp
  exit 0
fi

if [[ "$MKEXP2_MODE" == "list" ]]; then
  PrintDiscoverabilityLists
  exit 0
fi

if [[ "$MKEXP2_MODE" == "init" ]]; then
  InitExperiment
  exit 0
fi

if [[ "$MKEXP2_MODE" == "describe" ]]; then
  DescribePlugin "$MKEXP2_DESCRIBE_TARGET" "$MKEXP2_DESCRIBE_KIND"
  exit $?
fi

if [[ ! -f "$PWD/Experiment" ]]; then
  EchoFatal "no Experiment file in current directory"
  exit 1
fi

if (( MKEXP2_DO_GENERATE )); then
  PrepareGenerateOutputs
fi

typeset -a experiment_functions
experiment_functions=($(DiscoverExperimentFunctions "$PWD/Experiment"))
if [[ ${#experiment_functions[@]} -eq 0 ]]; then
  EchoFatal "no Experiment*() functions found in Experiment"
  exit 1
fi

if [[ "$MKEXP2_MODE" == "probe" ]]; then
  ProbeCommand "$PWD/Experiment" "${experiment_functions[@]}"
  exit $?
fi

if [[ "$MKEXP2_MODE" == "progress" ]]; then
  ProgressCommand "$PWD/Experiment" "${experiment_functions[@]}"
  exit $?
fi

if [[ "$MKEXP2_MODE" == "plot" ]]; then
  GeneratePlots
  exit $?
fi

local_fn=""
for local_fn in "${experiment_functions[@]}"; do
  local display_name=""
  display_name=$(DisplayExperimentName "$local_fn")
  EchoStep "Processing experiment $display_name"

  LoadExperimentFunctionState "$PWD/Experiment" "$local_fn"

  if (( MKEXP2_DO_CHECK )); then
    CheckCurrentExperiment "$display_name"
    continue
  fi

  install_mode=""
  install_mode=$(ResolveRunProperty "slurm.install.mode" "local")

  if (( MKEXP2_DO_INSTALL )); then
    if [[ "$_system" == "slurm" && "$install_mode" == "job" && "$MKEXP2_MODE" == "all" ]]; then
      EchoStep "Deferring install to Slurm install job for $display_name"
      MKEXP2_SLURM_INSTALL_JOB_REQUIRED=1
    else
      InstallCurrentExperiment "$display_name"
    fi
  fi

  if (( MKEXP2_DO_GENERATE )); then
    GenerateCurrentExperiment "$local_fn"
    if [[ "$(ResolveRunProperty "parse.auto" "false")" == "true" ]]; then
      MKEXP2_PARSE_AUTO_REQUIRED=1
    fi
  fi
done

if (( MKEXP2_DO_GENERATE )); then
  FinalizeGenerateOutputs
fi

if (( MKEXP2_DO_PARSE )); then
  ParseLogs
fi

if (( MKEXP2_DO_CHECK )); then
  FinalizeChecks
fi
